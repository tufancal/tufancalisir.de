---
import Layout from "@/src/layouts/Layout.astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import { useStoryblokApi } from "@storyblok/astro";
import { extractSeoData } from "@/src/utils/storyblok";
import Breadcrumb from "@/src/components/molecules/Breadcrumb.astro";
import { getStoryblokVersion } from "@/src/utils/env";
import { createWebPageSchema } from "@/src/utils/jsonld";

export async function getStaticPaths() {
  const sbApi = useStoryblokApi();

  // Fetch all stories except blog posts and global content
  const { data } = await sbApi.get("cdn/stories", {
    version: getStoryblokVersion(),
    excluding_slugs: "home,blog/*,global/*",
  });

  const stories = Object.values(data.stories);

  return stories.map((story: any) => {
    return {
      params: { slug: story.slug },
    };
  });
}

const sbApi = useStoryblokApi();
const { slug } = Astro.params;
const contentVersion = getStoryblokVersion();

let content, seo;

try {
  const { data } = await sbApi.get(`cdn/stories/${slug}`, {
    version: contentVersion,
  });

  content = data.story.content;
  seo = extractSeoData(content);
} catch (error) {
  return Astro.redirect("/404");
}

// Fetch global SEO data
const { data: seoData } = await sbApi.get("cdn/stories/global/seo", {
  version: contentVersion,
});
const globalSeo = seoData.story.content;

const baseUrl = Astro.url.origin;
const pageUrl = Astro.url.href;
const breadcrumbTitle = seo.title.split(" | ")[0];
const breadcrumbs = [{ name: "Home", url: "/" }, { name: breadcrumbTitle }];

// Create WebPage schema
const jsonld = createWebPageSchema({
  name: seo.title,
  url: pageUrl,
  description: seo.description,
  siteName: globalSeo.siteName,
  siteUrl: baseUrl,
  breadcrumbs,
  baseUrl,
});

const noindexPages = ["datenschutz", "impressum"];
const shouldNoindex = noindexPages.includes(slug);
---

<Layout seoPage={seo} jsonld={jsonld} noindex={shouldNoindex}>
  <Breadcrumb items={breadcrumbs} />
  <StoryblokComponent blok={content} />
</Layout>
